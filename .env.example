# BirdSong Bridge — environment variables
# Copy this file to `.env` and paste in your real keys.
# Every key below is FREE. `.env` is git-ignored — never commit real keys.

# Google AI Studio — powers the LLM agents (ADK uses GOOGLE_API_KEY).
# Free Flash / Flash-Lite tier. Get one at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_ai_studio_key_here

# eBird API 2.0 — regional plausibility + recent-sightings checks.
# Free, auto-generated at: https://ebird.org/api/keygen
EBIRD_API_KEY=your_ebird_key_here

# xeno-canto v3 — a real reference recording of the identified call.
# Free; find it on your account page at: https://xeno-canto.org
XENO_CANTO_API_KEY=your_xeno_canto_key_here

# iNaturalist (species facts + conservation status) needs NO key for the
# read-only taxa lookups this project uses.
# BirdNET runs locally via birdnetlib and needs NO key.

# --- Optional ---
# Restrict CORS in production (comma-separated origins). Defaults to "*".
# CORS_ALLOWED_ORIGINS=https://your-frontend-url.run.app

# Override the models if you like (defaults shown).
# BIRDSONG_CREATIVE_MODEL=gemini-2.5-flash-lite
